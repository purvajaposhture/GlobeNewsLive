.env.local

# Telegram Bot Token — MUST be set for the bot to work
# Main GlobeNewsLive Bot (8142303105:AAFk_x7vmRg2D8u9i-ys_lsIlpxaa4m3mW4)
TELEGRAM_BOT_TOKEN=8142303105:AAFk_x7vmRg2D8u9i-ys_lsIlpxaa4m3mW4

# Iran Alert Bot Token (optional — separate alert bot)
# IRAN_ALERT_BOT_TOKEN=your_alert_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# Push Notification VAPID Keys
# Generate keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:admin@globenews.live

# Optional: Database for storing subscriptions (default: in-memory)
# DATABASE_URL=postgresql://...

# Optional: Redis for pub/sub push (default: in-memory)
# REDIS_URL=redis://localhost:6379
